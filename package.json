{
  "name": "@bleckert/football-simulator",
  "version": "2.0.0",
  "description": "A TypeScript football match simulator for football manager games.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "sideEffects": false,
  "scripts": {
    "start": "npm run demo",
    "demo": "vite --host 127.0.0.1",
    "demo:build": "vite build",
    "analyse": "TS_NODE_PREFER_TS_EXTS=true node --loader ts-node/esm --experimental-specifier-resolution=node test/analyse.ts",
    "test": "npm run test:realtime && npm run test:calibration && npm run test:season",
    "test:realtime": "TS_NODE_PREFER_TS_EXTS=true node --loader ts-node/esm --experimental-specifier-resolution=node test/realtime.ts",
    "test:calibration": "TS_NODE_PREFER_TS_EXTS=true node --loader ts-node/esm --experimental-specifier-resolution=node test/calibration.ts",
    "test:season": "TS_NODE_PREFER_TS_EXTS=true node --loader ts-node/esm --experimental-specifier-resolution=node test/season.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run typecheck && vite build --config vite.library.config.ts",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run build"
  },
  "keywords": [
    "football",
    "soccer",
    "simulator",
    "match-engine",
    "football-manager",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tbleckert/football-simulator.git"
  },
  "bugs": {
    "url": "https://github.com/tbleckert/football-simulator/issues"
  },
  "homepage": "https://github.com/tbleckert/football-simulator#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.7",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^22.0.0",
    "svelte": "^5.0.0",
    "ts-node": "^10.8.1",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^5.0.0"
  },
  "dependencies": {
    "events": "^3.3.0"
  }
}
